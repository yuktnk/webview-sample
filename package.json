{
  "name": "webview-sample",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "local": "vite --mode local",
    "build:local": "vite build --mode local",
    "build:dev": "vite build --mode dev",
    "build:stg": "vite build --mode stg",
    "build:prd": "vite build --mode prd",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "knip": "knip",
    "format": "prettier --write src *.ts .storybook .claude",
    "format:check": "prettier --check src *.ts .storybook .claude",
    "test:visual": "playwright test --project=visual --update-snapshots",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "a11y": "playwright test --project=a11y",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static",
    "perf": "lighthouse https://localhost:5173 --output=json --output-path=./dist/lighthouse.json",
    "bundle": "vite build && echo '✅ Bundle analysis generated: dist/bundle-analysis.html'"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@tanstack/react-router": "^1.168.18",
    "clsx": "^2.1.1",
    "msw": "^2.13.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "axe-playwright": "^1.2.3",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@secretlint/secretlint-rule-preset-recommend": "^11.6.0",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/eslint-plugin-query": "^5.99.0",
    "@tanstack/router-plugin": "^1.167.18",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "4.1.4",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/ui": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.5",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "knip": "^6.4.0",
    "lefthook": "^2.1.5",
    "lighthouse": "^12.3.0",
    "msw-storybook-addon": "^2.0.7",
    "playwright": "^1.59.1",
    "prettier": "^3.8.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "secretlint": "^11.6.0",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook",
      "msw"
    ]
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
